@model CarDetailsViewModel
@{
    ViewData["Title"] = $"{Model.Car.Brand} {Model.Car.Model}";
}

<section class="page-header">
    <div class="container">
        <h1>@Model.Car.Brand @Model.Car.Model</h1>
        <p>@Model.Car.Year | @Model.Car.BodyType | @Model.Car.Condition | @Model.Car.Status</p>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="detail-gallery mb-3">
                    <img src="@Model.Car.ImageUrl" alt="@($"{Model.Car.Brand} {Model.Car.Model}")" class="img-fluid rounded-4 w-100 hero-image" />
                </div>
                <div class="row g-3">
                    @foreach (var image in Model.GalleryImages)
                    {
                        <div class="col-6 col-md-4">
                            <img src="@image" alt="Gallery image" class="img-fluid rounded-4 thumb-image" />
                        </div>
                    }
                </div>
                <div class="spec-card mt-4">
                    <h3>Vehicle Specifications</h3>
                    <div class="spec-grid">
                        <div><span>Price</span><strong>R @Model.Car.Price.ToString("N0")</strong></div>
                        <div><span>Mileage</span><strong>@Model.Car.Mileage.ToString("N0") km</strong></div>
                        <div><span>Fuel Type</span><strong>@Model.Car.FuelType</strong></div>
                        <div><span>Transmission</span><strong>@Model.Car.Transmission</strong></div>
                        <div><span>Color</span><strong>@Model.Car.Color</strong></div>
                        <div><span>Views</span><strong>@Model.Car.ViewCount</strong></div>
                    </div>
                    <p class="mt-4 mb-0">@Model.Car.Description</p>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="sticky-panel">
                    <span class="car-status">@Model.Car.Status</span>
                    <h2>R @Model.Car.Price.ToString("N0")</h2>
                    <p class="text-muted">Estimated from R @Model.EstimatedMonthlyPayment.ToString("N0") / month over 60 months.</p>

                    @if (Model.CanCustomerInteract)
                    {
                        if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <form asp-controller="Favorites" asp-action="Toggle" method="post" class="mb-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="carId" value="@Model.Car.CarId" />
                                <button class="btn btn-outline-dark w-100" type="submit">@(Model.IsFavorite ? "Remove from Favorites" : "Save to Favorites")</button>
                            </form>

                            <form asp-controller="Bookings" asp-action="Create" method="post" class="panel-form mb-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="CarId" value="@Model.Car.CarId" />
                                <h4>Book Test Drive</h4>
                                <input type="date" name="PreferredDate" class="form-control mb-2" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                                <textarea name="Notes" class="form-control mb-3" rows="3" placeholder="Preferred time or special requests"></textarea>
                                <button class="btn btn-accent w-100" type="submit">Request Test Drive</button>
                            </form>

                            <form asp-controller="Purchases" asp-action="Create" method="post" class="panel-form purchase-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="CarId" value="@Model.Car.CarId" />
                                <h4>Purchase Request</h4>
                                <input type="number" name="AmountPaid" class="form-control mb-2" min="0" step="0.01" placeholder="Deposit amount" />
                                <input type="email" name="ConfirmationEmail" class="form-control mb-2" placeholder="Purchase confirmation email" />
                                <select name="PaymentMethod" class="form-select mb-2 payment-method-select">
                                    <option>Stripe Test</option>
                                    <option>EFT</option>
                                    <option>Cash Deposit</option>
                                </select>
                                <div class="stripe-test-panel mb-3">
                                    <p class="small text-muted mb-2">Demo Stripe mode: use card number 4242 4242 4242 4242 with any future expiry date and any 3-digit CVC.</p>
                                    <input type="text" name="CardholderName" class="form-control mb-2" placeholder="Name on card" />
                                    <input type="text" name="CardNumber" class="form-control mb-2" placeholder="4242 4242 4242 4242" />
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <input type="text" name="ExpiryDate" class="form-control" placeholder="MM/YY" />
                                        </div>
                                        <div class="col-6">
                                            <input type="text" name="Cvc" class="form-control" placeholder="CVC" />
                                        </div>
                                    </div>
                                </div>
                                <input type="text" name="ProofOfPayment" class="form-control mb-3" placeholder="Reference or proof URL for non-card methods" />
                                <button class="btn btn-dark w-100" type="submit">Purchase Now</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-accent w-100" asp-area="Identity" asp-page="/Account/Login">Login to Book or Buy</a>
                        }
                    }
                    else
                    {
                        <div class="content-card p-0 border-0 shadow-none">
                            <h4>This vehicle is not currently available to purchase</h4>
                            <p class="mb-0">The car has either been reserved or sold, so customer buying and booking actions are disabled.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<section class="pb-5 bg-soft">
    <div class="container">
        <div class="section-heading">
            <span class="eyebrow">Similar Cars</span>
            <h2>You may also like</h2>
        </div>
        <div class="row g-4">
            @foreach (var car in Model.SimilarCars)
            {
                <div class="col-md-6 col-xl-4">
                    <partial name="_CarCard" model="car" />
                </div>
            }
        </div>
    </div>
</section>
