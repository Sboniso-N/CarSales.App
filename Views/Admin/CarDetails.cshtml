@model CarDetailsViewModel
@{
    ViewData["Title"] = "Admin Car Details";
}

<section class="page-header">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1>@Model.Car.Brand @Model.Car.Model</h1>
            <p>Admin vehicle view with inventory and sales context.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-accent" asp-action="EditCar" asp-route-id="@Model.Car.CarId">Edit Listing</a>
            <a class="btn btn-outline-dark" asp-action="Cars">Back to Inventory</a>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-7">
                <img src="@Model.Car.ImageUrl" alt="@($"{Model.Car.Brand} {Model.Car.Model}")" class="img-fluid rounded-4 w-100 hero-image mb-3" />
                <div class="row g-3">
                    @foreach (var image in Model.GalleryImages)
                    {
                        <div class="col-6 col-md-4">
                            <img src="@image" alt="Gallery image" class="img-fluid rounded-4 thumb-image" />
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-5">
                <div class="sticky-panel">
                    <span class="car-status">@Model.Car.Status</span>
                    <h2>R @Model.Car.Price.ToString("N0")</h2>
                    <div class="spec-grid mt-3">
                        <div><span>Year</span><strong>@Model.Car.Year</strong></div>
                        <div><span>Mileage</span><strong>@Model.Car.Mileage.ToString("N0") km</strong></div>
                        <div><span>Fuel</span><strong>@Model.Car.FuelType</strong></div>
                        <div><span>Transmission</span><strong>@Model.Car.Transmission</strong></div>
                        <div><span>View Count</span><strong>@Model.Car.ViewCount</strong></div>
                        <div><span>Finance Estimate</span><strong>R @Model.EstimatedMonthlyPayment.ToString("N0")</strong></div>
                    </div>
                    <div class="panel-form mt-3">
                        <h4>Admin Actions</h4>
                        <p class="mb-2">Customer purchase, booking, and favorites actions are intentionally hidden for admin accounts.</p>
                        <div class="d-grid gap-2">
                            <a class="btn btn-dark" asp-action="Purchases">Manage Purchases</a>
                            <a class="btn btn-outline-dark" asp-action="Bookings">Manage Bookings</a>
                            <a class="btn btn-outline-dark" asp-action="Users">Manage Users</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="content-card mt-4">
            <h3>Description</h3>
            <p class="mb-0">@Model.Car.Description</p>
        </div>
    </div>
</section>
