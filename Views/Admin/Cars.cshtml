@model IEnumerable<Car>
@{
    ViewData["Title"] = "Manage Cars";
}

<section class="page-header">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1>Inventory Management</h1>
            <p>Full CRUD for car listings, status, media, and pricing.</p>
        </div>
        <a class="btn btn-accent" asp-action="CreateCar">Add Vehicle</a>
    </div>
</section>

<div class="container pb-5">
    <div class="content-card">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr><th>Vehicle</th><th>Price</th><th>Status</th><th>Date Added</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var car in Model)
                {
                    <tr>
                        <td>@car.Brand @car.Model (@car.Year)</td>
                        <td>R @car.Price.ToString("N0")</td>
                        <td>@car.Status</td>
                        <td>@car.DateAdded.ToShortDateString()</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-dark" asp-action="CarDetails" asp-route-id="@car.CarId">View</a>
                            <a class="btn btn-sm btn-outline-dark" asp-action="EditCar" asp-route-id="@car.CarId">Edit</a>
                            <form asp-action="DeleteCar" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@car.CarId" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
