@model CarFormViewModel
@{
    ViewData["Title"] = Model.CarId.HasValue ? "Edit Car" : "Create Car";
}

<section class="page-header">
    <div class="container">
        <h1>@ViewData["Title"]</h1>
        <p>Create or update dealership inventory records.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="content-card">
        <form method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input asp-for="CarId" type="hidden" />
            <div class="col-md-6"><label asp-for="Brand" class="form-label"></label><input asp-for="Brand" class="form-control" /><span asp-validation-for="Brand" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="Model" class="form-label"></label><input asp-for="Model" class="form-control" /><span asp-validation-for="Model" class="text-danger"></span></div>
            <div class="col-md-3"><label asp-for="Year" class="form-label"></label><input asp-for="Year" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="Price" class="form-label"></label><input asp-for="Price" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="Mileage" class="form-label"></label><input asp-for="Mileage" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="Color" class="form-label"></label><input asp-for="Color" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="FuelType" class="form-label"></label><select asp-for="FuelType" asp-items="Html.GetEnumSelectList<FuelType>()" class="form-select"></select></div>
            <div class="col-md-3"><label asp-for="Transmission" class="form-label"></label><select asp-for="Transmission" asp-items="Html.GetEnumSelectList<TransmissionType>()" class="form-select"></select></div>
            <div class="col-md-3"><label asp-for="BodyType" class="form-label"></label><select asp-for="BodyType" asp-items="Html.GetEnumSelectList<BodyType>()" class="form-select"></select></div>
            <div class="col-md-3"><label asp-for="Condition" class="form-label"></label><select asp-for="Condition" asp-items="Html.GetEnumSelectList<CarCondition>()" class="form-select"></select></div>
            <div class="col-md-4"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<CarStatus>()" class="form-select"></select></div>
            <div class="col-md-8"><label asp-for="ImageUrl" class="form-label"></label><input asp-for="ImageUrl" class="form-control" /></div>
            <div class="col-12"><label asp-for="GalleryImages" class="form-label"></label><textarea asp-for="GalleryImages" class="form-control" rows="2"></textarea></div>
            <div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="5"></textarea></div>
            <div class="col-12">
                <button class="btn btn-accent" type="submit">Save Listing</button>
                <a class="btn btn-outline-dark" asp-action="Cars">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
