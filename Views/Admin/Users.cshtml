@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "Users";
}

<section class="page-header">
    <div class="container">
        <h1>User Management</h1>
        <p>Registered customers and staff accounts across the platform.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="content-card">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr><th>Name</th><th>Email</th><th>Phone</th><th>Joined</th></tr>
                </thead>
                <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@(string.IsNullOrWhiteSpace(user.FullName) ? "Unspecified" : user.FullName)</td>
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                        <td>@user.DateCreated.ToShortDateString()</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
